# ─── AI Compass EU — Environment Variables ───
#
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git (it's in .gitignore).

# Database connection (Vercel Postgres)
# For local dev: postgresql://user@localhost:5432/aicompass
# On Vercel: automatically set when you provision Vercel Postgres
DATABASE_URL=""

# Admin password hash (bcrypt)
# Generate: node -e "require('bcryptjs').hash('YOUR_PASSWORD', 12).then(console.log)"
# IMPORTANT: Escape every $ as \$ (Next.js interprets $ as variable expansion)
ADMIN_PASSWORD_HASH=""

# JWT secret for signing session tokens (random 64-char hex)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=""

# TOTP secret for admin 2FA (base32, 32 chars)
# Generate: node -e "const c='ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';let s='';for(let i=0;i<32;i++)s+=c[Math.floor(Math.random()*c.length)];console.log(s)"
TOTP_SECRET=""

# Resend API key for magic links and digest emails
# Sign up: https://resend.com (free tier: 3,000 emails/month)
# Leave empty for dev (emails logged to console)
RESEND_API_KEY=""

# Base URL for magic links and absolute URLs
# Local dev: http://localhost:3000
# Production: https://yourdomain.eu
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# DeepL API key for auto-translation (14 EU languages)
# Sign up: https://www.deepl.com/pro-api (free tier: 500,000 chars/month)
# Leave empty for dev (English-only mode)
DEEPL_API_KEY=""

# Anthropic API key for RAG chatbot (Claude Haiku)
# Sign up: https://console.anthropic.com
# Leave empty for dev (placeholder responses)
ANTHROPIC_API_KEY=""

# ─── Stripe (Payments) ───
# Sign up: https://stripe.com
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production
STRIPE_SECRET_KEY=""

# Create a product "AI Compass EU Pro" at €49/month in Stripe Dashboard
# Copy the Price ID (starts with price_...)
STRIPE_PRO_PRICE_ID=""

# Set up webhook at: https://yourdomain.eu/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.deleted
# Copy the Signing Secret (starts with whsec_...)
STRIPE_WEBHOOK_SECRET=""

# ─── Plausible Analytics ───
# Sign up: https://plausible.io
# Set to your production domain (e.g., "aicompass.eu")
# Leave empty to disable analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# ─── Email Sender ───
# Custom "From" address for outbound emails
# Requires domain verification in Resend
# Default: "AI Compass EU <noreply@aicompass.eu>"
FROM_EMAIL=""
