generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A regulatory framework that AI systems are scored against.
/// Examples: EU AI Act, GDPR, DORA.
///
/// Contains meta information (issuing authority, enforcement type, penalties,
/// applicable regions) plus structured sections and policy statements.
model RegulatoryFramework {
  id                String             @id @default(cuid())
  slug              String             @unique
  name              String
  description       String
  content           String             @default("")
  badgeType         String
  criteriaCount     Int                @default(0)
  effectiveDate     String             @default("")
  published         Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  applicableRegions String             @default("")
  enforcementType   String             @default("")
  issuingAuthority  String             @default("")
  maxPenalty        String             @default("")
  officialUrl       String             @default("")
  purpose           String             @default("")
  scores            AssessmentScore[]
  changelog         ChangeLog[]
  sections          FrameworkSection[]
  industries        Industry[]         @relation("IndustryToRegulatoryFramework")
  subscribers       Subscriber[]       @relation("RegulatoryFrameworkToSubscriber")

  @@index([published])
  @@index([name])
}

/// A section or chapter within a regulatory framework.
/// Example: "Risk Management System" under the EU AI Act.
/// Contains ordered policy statements.
model FrameworkSection {
  id              String              @id @default(cuid())
  title           String
  description     String              @default("")
  sortOrder       Int                 @default(0)
  frameworkId     String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  dimensionScores DimensionScore[]
  framework       RegulatoryFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  statements      PolicyStatement[]
}

/// A specific policy requirement within a framework section.
/// Contains the actual requirement text and a plain-language commentary
/// explaining what it means for organisations.
model PolicyStatement {
  id         String           @id @default(cuid())
  reference  String           @default("")
  statement  String
  commentary String           @default("")
  sortOrder  Int              @default(0)
  sectionId  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  sourceNote String           @default("")
  sourceUrl  String           @default("")
  section    FrameworkSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([sectionId])
}

/// An industry sector (e.g., Financial Services, Healthcare).
/// Connected to AI systems and regulatory frameworks via many-to-many.
model Industry {
  id         String                @id @default(cuid())
  slug       String                @unique
  name       String
  colorClass String                @default("")
  iconName   String                @default("building")
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  systems    AISystem[]            @relation("AISystemToIndustry")
  frameworks RegulatoryFramework[] @relation("IndustryToRegulatoryFramework")
}

/// A compliance score linking one AI system to one regulatory framework.
/// Each system can have at most one score per framework.
model AssessmentScore {
  id          String              @id @default(cuid())
  score       String
  systemId    String
  frameworkId String
  framework   RegulatoryFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  system      AISystem            @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, frameworkId])
}

/// Per-section (dimension) score for cross-framework reports and spider charts.
/// Links one AI system to one framework section with a letter grade + commentary.
/// The spider chart uses these scores as axes — larger area = better compliance.
model DimensionScore {
  id         String           @id @default(cuid())
  score      String
  commentary String           @default("")
  systemId   String
  sectionId  String
  section    FrameworkSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  system     AISystem         @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, sectionId])
}

/// An AI system rated for EU regulatory compliance.
/// Each entry appears as a card on the website with per-framework scores.
/// Extended fields provide the full vendor profile shown on the assessment page.
model AISystem {
  id               String            @id @default(cuid())
  slug             String            @unique
  vendor           String
  name             String
  type             String
  risk             String
  description      String
  category         String
  status           String            @default("active")
  featured         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accessControls   String            @default("")
  aiActStatus      String            @default("")
  assessedAt       DateTime?
  assessmentNote   String            @default("")
  biasTesting      String            @default("")
  certifications   String            @default("")
  dataPortability  String            @default("")
  dataProcessing   String            @default("")
  dataStorage      String            @default("")
  dpaDetails       String            @default("")
  encryptionInfo   String            @default("")
  euPresence       String            @default("")
  euResidency      String            @default("")
  exitTerms        String            @default("")
  explainability   String            @default("")
  gdprStatus       String            @default("")
  ipTerms          String            @default("")
  modelDocs        String            @default("")
  slaDetails       String            @default("")
  subprocessors    String            @default("")
  trainingDataUse  String            @default("")
  useCases         String            @default("")
  vendorHq         String            @default("")
  capabilityType   String            @default("")
  customerCount    String            @default("")
  customerStories  String            @default("")
  deploymentModel  String            @default("")
  employeeCount    String            @default("")
  foundedYear      Int?
  fundingStatus    String            @default("")
  marketPresence   String            @default("")
  notableCustomers String            @default("")
  sourceModel      String            @default("")
  scores           AssessmentScore[]
  changelog        ChangeLog[]
  dimensionScores  DimensionScore[]
  reviewTasks      ReviewTask[]
  sources          Source[]
  claims           SystemClaim[]
  companies        Company[]         @relation("AISystemToCompany")
  industries       Industry[]        @relation("AISystemToIndustry")
  subscribers      Subscriber[]      @relation("AISystemToSubscriber")
}

/// A registry of authoritative URLs per AI system.
/// Populated by analysts when they onboard a vendor.
/// The fetcher reads this list and pulls fresh snapshots on a schedule.
model Source {
  id                      String           @id @default(cuid())
  systemId                String
  url                     String
  label                   String
  tier                    Int              @default(1)
  active                  Boolean          @default(true)
  notes                   String           @default("")
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  fetchStrategy           String           @default("direct")
  lastExtractedSnapshotId String?
  reviewTasks             ReviewTask[]
  system                  AISystem         @relation(fields: [systemId], references: [id], onDelete: Cascade)
  snapshots               SourceSnapshot[]
  claims                  SystemClaim[]

  @@unique([systemId, url])
  @@index([systemId])
  @@index([tier])
}

/// A point-in-time snapshot of a Source URL. Enables diff detection:
/// when contentHash changes, affected claims are queued for re-verification.
/// Raw text retained so we can show the auditor the exact text we relied on.
model SourceSnapshot {
  id            String        @id @default(cuid())
  sourceId      String
  fetchedAt     DateTime      @default(now())
  contentHash   String
  rawText       String
  screenshotUrl String        @default("")
  status        String        @default("success")
  errorMessage  String        @default("")
  source        Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  claims        SystemClaim[]

  @@unique([sourceId, fetchedAt])
  @@index([sourceId, fetchedAt])
  @@index([contentHash])
}

/// One claim per (system × field) — the evidence-backed replacement for
/// the free-text columns on AISystem (dpaDetails, certifications, etc.).
/// Every claim carries its evidence quote + source URL + verification date.
/// Admin approves before the claim goes live on the public page.
model SystemClaim {
  id            String          @id @default(cuid())
  systemId      String
  field         String
  value         String
  evidenceQuote String
  sourceId      String?
  snapshotId    String?
  verifiedBy    String          @default("")
  verifiedAt    DateTime?
  confidence    String          @default("medium")
  status        String          @default("draft")
  retiredAt     DateTime?
  retiredReason String          @default("")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  reviewTasks   ReviewTask[]
  snapshot      SourceSnapshot? @relation(fields: [snapshotId], references: [id])
  source        Source?         @relation(fields: [sourceId], references: [id])
  system        AISystem        @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, field, status])
  @@index([systemId, status])
  @@index([status, verifiedAt])
  @@index([field])
  @@index([snapshotId])
}

/// The review queue. Tasks created automatically (fetcher diff, age
/// threshold) or manually (analyst onboarding, customer report).
/// Analysts drain this queue; everything not "done" is either in progress
/// or overdue.
model ReviewTask {
  id           String       @id @default(cuid())
  type         String
  systemId     String?
  claimId      String?
  sourceId     String?
  priority     String       @default("normal")
  status       String       @default("open")
  assignedToId String?
  dueBy        DateTime?
  title        String
  notes        String       @default("")
  resolvedAt   DateTime?
  resolution   String       @default("")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  assignedTo   AdminUser?   @relation(fields: [assignedToId], references: [id])
  claim        SystemClaim? @relation(fields: [claimId], references: [id], onDelete: Cascade)
  source       Source?      @relation(fields: [sourceId], references: [id])
  system       AISystem?    @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@index([status, dueBy])
  @@index([systemId, status])
  @@index([assignedToId, status])
}

/// A versioned change log entry tracking updates to frameworks or AI systems.
/// Every significant change must reference a trusted source.
/// Displayed publicly as "Version History" on framework and assessment pages.
model ChangeLog {
  id          String               @id @default(cuid())
  date        DateTime             @default(now())
  title       String
  description String
  changeType  String               @default("update")
  sourceUrl   String               @default("")
  sourceLabel String               @default("")
  author      String               @default("")
  frameworkId String?
  systemId    String?
  createdAt   DateTime             @default(now())
  framework   RegulatoryFramework? @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  system      AISystem?            @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([frameworkId])
  @@index([systemId])
}

/// Admin users who can access the admin panel.
/// Roles: "owner" (unrestricted), "admin" (full admin), "editor" (content only).
/// Owner also bypasses all public-site tier restrictions (full testing access).
model AdminUser {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String       @default("")
  passwordHash  String
  totpSecret    String       @default("")
  totpEnabled   Boolean      @default(false)
  role          String       @default("editor")
  active        Boolean      @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  assignedCases Case[]
  reviewTasks   ReviewTask[]
}

/// Company / Organisation — groups subscribers and tracks AI system usage.
/// Used by the admin CRM to manage customer relationships.
model Company {
  id          String       @id @default(cuid())
  name        String
  domain      String       @default("")
  industry    String       @default("")
  country     String       @default("")
  size        String       @default("")
  tier        String       @default("free")
  notes       String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  cases       Case[]
  subscribers Subscriber[]
  aiSystems   AISystem[]   @relation("AISystemToCompany")
}

/// Case — A support request, consulting inquiry, or tracked interaction.
/// Managed by admins. Linked to a subscriber and optionally a company.
model Case {
  id           String      @id @default(cuid())
  title        String
  description  String      @default("")
  status       String      @default("open")
  priority     String      @default("normal")
  category     String      @default("general")
  subscriberId String?
  companyId    String?
  assignedToId String?
  resolvedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  assignedTo   AdminUser?  @relation(fields: [assignedToId], references: [id])
  company      Company?    @relation(fields: [companyId], references: [id])
  subscriber   Subscriber? @relation(fields: [subscriberId], references: [id])
}

/// GDPR-compliant: stores only email + preferences + consent record.
/// No passwords, no names, no tracking, no profiling.
model Subscriber {
  id                   String                @id @default(cuid())
  email                String                @unique
  verified             Boolean               @default(false)
  digestEnabled        Boolean               @default(true)
  digestFrequency      String                @default("daily")
  consentDate          DateTime?
  consentText          String                @default("")
  magicToken           String?
  magicTokenExp        DateTime?
  sessionToken         String?
  sessionExp           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  stripeCustomerId     String?
  stripeSubscriptionId String?
  tier                 String                @default("free")
  tierExpiresAt        DateTime?
  industry             String                @default("")
  orgSize              String                @default("")
  platforms            String                @default("")
  role                 String                @default("")
  companyId            String?
  name                 String                @default("")
  cases                Case[]
  company              Company?              @relation(fields: [companyId], references: [id])
  systems              AISystem[]            @relation("AISystemToSubscriber")
  frameworks           RegulatoryFramework[] @relation("RegulatoryFrameworkToSubscriber")

  @@index([stripeCustomerId])
}

/// Tracks sent digest emails for GDPR compliance and delivery monitoring.
model DigestLog {
  id           String   @id @default(cuid())
  subscriberId String
  sentAt       DateTime @default(now())
  itemCount    Int
  status       String   @default("sent")

  @@index([subscriberId])
}

/// Cached translations of database content in EU languages.
/// Auto-generated by DeepL API when content is created/updated.
/// Generic table: any entity type + field can be translated.
model Translation {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  locale     String
  field      String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId, locale, field])
}

/// Rate limiting for the chatbot — tracks daily question count per anonymous visitor.
/// Uses a fingerprint cookie (survives page reload) to prevent abuse.
model ChatUsage {
  id          String @id @default(cuid())
  fingerprint String
  date        String
  count       Int    @default(0)

  @@unique([fingerprint, date])
}

/// Logs all chat interactions for admin review and abuse detection.
model ChatLog {
  id           String   @id @default(cuid())
  fingerprint  String
  subscriberId String?
  question     String
  answer       String
  locale       String
  blocked      Boolean  @default(false)
  blockReason  String   @default("")
  createdAt    DateTime @default(now())

  @@index([fingerprint])
  @@index([createdAt])
}

/// Feedback submitted via the contact form.
model Feedback {
  id        String   @id @default(cuid())
  name      String
  email     String
  category  String
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A discussion thread where domain experts debate a topic.
/// The CEO (user) receives the summary via Telegram and makes the call.
model ExpertDiscussion {
  id          String           @id @default(cuid())
  topic       String
  context     String           @default("")
  status      String           @default("in_progress")
  consensus   Boolean          @default(false)
  summary     String           @default("")
  ceoDecision String           @default("")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  responses   ExpertResponse[]

  @@index([status])
  @@index([createdAt])
}

/// An individual expert's response within a discussion.
model ExpertResponse {
  id           String           @id @default(cuid())
  discussionId String
  expertId     String
  expertName   String
  emoji        String           @default("")
  round        Int              @default(1)
  response     String
  position     String           @default("neutral")
  createdAt    DateTime         @default(now())
  discussion   ExpertDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@index([discussionId])
}

/// Stores Telegram messages for two-way CEO communication.
/// Incoming messages from the CEO are stored and read by Claude Code sessions.
/// Outgoing messages are logged for audit trail.
model TelegramMessage {
  id               String    @id @default(cuid())
  telegramUpdateId Int       @unique @default(0)
  text             String
  fromName         String    @default("")
  direction        String    @default("incoming")
  processedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([direction, processedAt])
  @@index([createdAt])
}

/// Admin-curated external source URLs the chatbot can reference.
model ApprovedSource {
  id          String   @id @default(cuid())
  url         String   @unique
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
}

/// A COO-led work cycle where agents autonomously review their domains.
/// Runs 3x/day via Vercel Cron. Results feed into the daily digest.
model WorkCycle {
  id             String           @id @default(cuid())
  date           String
  cycleNumber    Int
  status         String           @default("running")
  agentsAssigned Int              @default(0)
  findingsCount  Int              @default(0)
  decisionsCount Int              @default(0)
  durationMs     Int              @default(0)
  error          String           @default("")
  createdAt      DateTime         @default(now())
  reports        AgentReport[]
  decisions      DigestDecision[]

  @@unique([date, cycleNumber])
  @@index([date])
}

/// An individual agent's structured report from a work cycle or daily digest.
model AgentReport {
  id          String       @id @default(cuid())
  agentId     String
  agentName   String
  emoji       String       @default("")
  done        String       @default("")
  highestRisk String       @default("")
  action      String       @default("")
  advice      String       @default("")
  nextStep    String       @default("")
  hasFindings Boolean      @default(false)
  rawResponse String       @default("")
  workCycleId String?
  digestId    String?
  createdAt   DateTime     @default(now())
  digest      DailyDigest? @relation(fields: [digestId], references: [id], onDelete: Cascade)
  workCycle   WorkCycle?   @relation(fields: [workCycleId], references: [id], onDelete: Cascade)

  @@index([workCycleId])
  @@index([digestId])
  @@index([agentId, createdAt])
}

/// An autonomous decision made by the COO during a work cycle.
model DigestDecision {
  id          String       @id @default(cuid())
  description String
  riskLevel   String
  rationale   String       @default("")
  precedent   String       @default("")
  autonomous  Boolean      @default(true)
  workCycleId String?
  digestId    String?
  createdAt   DateTime     @default(now())
  digest      DailyDigest? @relation(fields: [digestId], references: [id], onDelete: Cascade)
  workCycle   WorkCycle?   @relation(fields: [workCycleId], references: [id], onDelete: Cascade)

  @@index([workCycleId])
  @@index([digestId])
}

/// The daily digest — one per day, sent to CEO at 20:00 Paris time.
/// Synthesizes all work cycle findings into a single Telegram message.
model DailyDigest {
  id                  String           @id @default(cuid())
  date                String           @unique
  status              String           @default("running")
  executiveSummary    String           @default("")
  autonomousDecisions Int              @default(0)
  escalations         Int              @default(0)
  durationMs          Int              @default(0)
  telegramMessageId   String           @default("")
  createdAt           DateTime         @default(now())
  reports             AgentReport[]
  decisions           DigestDecision[]

  @@index([date])
}
